--Choosing Top 10 Cities with Net_Profit greater than the Average Net Profit Grouped by Cities
WITH CTE AS 
(
SELECT  
	City, 
	ROUND(AVG(Net_Profit),2) as City_Benchmark
FROM 
	ev_charging_cleaned_data eccd 
GROUP BY 
	City
),
A AS
(
SELECT  
	e.City, 
	e.Net_Profit, 
	City_Benchmark,
	RANK()OVER(PARTITION BY e.City ORDER BY e.Net_Profit DESC) as Rank
FROM 
	ev_charging_cleaned_data e 
JOIN 
	CTE 
ON 
	e.City = CTE.City
WHERE 
	e.Net_Profit > City_Benchmark
)
SELECT 
	* 
FROM
	A
WHERE
	Rank <= 10
ORDER BY 
	City, 
	Net_Profit DESC;

