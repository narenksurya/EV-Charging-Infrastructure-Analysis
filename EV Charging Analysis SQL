-- Creating Profitability Tier
SELECT 
	Station_ID, 
	Charger_Type, 
	Net_Profit,
    CASE 
        WHEN Net_Profit > 500000 THEN 'High'
        WHEN Net_Profit BETWEEN 100000 AND 500000 THEN 'Medium'
        ELSE 'Low'
    END AS Profitability_Tier
FROM 
	ev_charging_cleaned_data eccd 
ORDER BY 
	Net_Profit DESC;

